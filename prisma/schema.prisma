//Tabla secundaria
//Relacion Many to Many 
model EventVolunteer {
  eventId Int
  volunteerId Int
  status ParticipationStatus @default(REGISTERED)
  registeredAt DateTime @default(now())
  //Un voluntario puede asistir a muchos eventos 
  volunteer Volunteer @relation(fields: [volunteerId],references: [id])
  //A un evento pueden asistir muchos voluntarios
  event Event @relation(fields: [eventId],references: [id])
  //Clave primaria compuesta para que un voluntario no se pueda apuntar mas de una vez a un evento
  @@id([eventId,volunteerId])
  @@map("events_volunteers")
}

