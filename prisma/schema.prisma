// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}
//Enums
enum Role {
  ADMIN
  COORDINATOR
  MODERATOR
  VOLUNTEER
  PYME_MANAGER
}
//Status
enum ProjectStatus {
  DRAFT
  PUBLISHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
enum EventStatus {
  PLANNED
  OPEN
  CLOSED
  COMPLETED
  CANCELLED
}
enum TaskStatus {
 OPEN
 IN_PROGRESS
 IN_REVIEW
 COMPLETED
 CANCELLED
}
enum AssignmentStatus {
  ASSIGNED
  ACCEPTED
  DECLINED
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REJECTED
}
enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}
enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}
enum ParticipationStatus {
  REGISTERED
  ATTENDED
  ABSENT
  CANCELLED
}
enum NewsStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}
//------
enum TaskPrio {
  LOW
  MEDIUM
  HIGH
}
enum Visibility { 
  PUBLIC
  PRIVATE
}
enum FileType {
  IMAGE
  VIDEO
  DOCUMENT
  OTHER
}

//--------------------------------------------------
//Schema (Tablas de la bd)
model User {
  id Int @id @default(autoincrement())
  name String @db.VarChar(100)
  email String @unique @db.VarChar(150)
  password String @db.VarChar(255)
  isActive Boolean
  createdAt DateTime @default(now())
  userRoles UserRole[]
  //Relacion 1 to 1 con voluntarios
  //Un usuario solo puede un voluntario y un voluntario solo puede ser un usuario
  volunteers Volunteer?
  //Relacion 1 to 1 con pillar
  //Pillar solo puede tener un coordinador
  //Es opcional para el usuario
  pillar Pillar?
  //Relacion 1 to Many
  //Un usuario puede crear muchos proyectos
  projects Project[]
  //Relacion 1 to Many
  //Un usuario puede crear muchos eventos
  events Event[]
  //Relacion 1 to Many
  //Un usuario puede crear muchas eventos
  tasks Task[]
  //Relacion 1 to Many
  //Un usuario puede revisar muchas evidencias de tareas
  evidenceReviewed TaskEvidence[]
  //Relacion 1 to 1
  //Una pyme solo puede tener un manager
  pyme PymeManager?
  @@map("users")
}
model UserRole{
  userId Int
  role Role
  user User @relation(fields: [userId], references: [id])
  //Con la clave primaria compuesta nos aseguramos de que no se repita esta convinacion
  //Es decir, un usuario no puede tener dos veces el mismo rol 
  @@id([userId,role])
  @@map("user_roles")
}

model Pillar {
  id Int @id @default(autoincrement())
  coordinatorId Int @unique
  name String @db.VarChar(100) 
  description String @db.Text
  iconUrl String 
  color String @db.VarChar(30)
  isActive Boolean @default(true)
  //Relacion 1 to 1 
  //Se puede cambiar de 1 to Many
  coordinator User? @relation(fields: [coordinatorId],references: [id])
  //Relacion 1 to Many 
  //Un pillar puede tener muchos proyectos
  projects Project []
  @@map("pillars")
}

model Volunteer {
  id Int @id @default(autoincrement())
  userId Int @unique //se pone unique para la relacion 1 to 1 
  phone String
  nationality String
  profession String
  emergencyContactName String
  emergencyContactPhone String
  inmediateAvailability Boolean
  //timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  //Relacion 1 to 1 con usuario
  user User @relation(fields: [userId], references: [id])
  //Relacion 1 to Many
  //Un voluntario puede tener muchas skills
  skills VolunteerSkill[]
  //Relacion 1 to Many
  //Un voluntario puede tener muchas disponibilidades
  availability VolunteerAvailability[]
  //Relacion 1 to Many
  //Un voluntario puede tener muchas tareas asignadas
  tasks TaskVolunteer[]
  //Relacion 1 to Many
  //Un voluntario puede tener muchas evidencias entregadas
  taskEvidences TaskEvidence[]
  //Relacion Many to Many
  //Un Voluntario puede participar en muchjos eventos
  events EventVolunteer[]
  //Relacion 1 to Many
  //Un Voluntario puede escribir muchas reseñas
  reviews ProjectReview[]
  @@map("volunteers")
}

model VolunteerAvailability {
  id Int @id @default(autoincrement())
  volunteerId Int
  startDate DateTime
  endDate DateTime
  notes String? @db.Text
  //timestamps
  createdAt DateTime @default(now()) 
  updatedAt DateTime @updatedAt
  //Una disponibilidad pertenece a un solo voluntario
  volunteer Volunteer @relation(fields: [volunteerId], references: [id])
  @@map("volunteer_availabilities")
}

model VolunteerSkill {
  id Int @id @default(autoincrement())
  volunteerId Int
  name String @db.VarChar(100)
  description String @db.Text
  //Una Skill pertenece solo a un voluntario
  volunteer Volunteer @relation(fields: [volunteerId],references: [id])
  @@map("volunteer_skills")
}

model Project {
  id Int @id @default(autoincrement())
  pillarId Int
  createdBY Int // id del usuario que creo el proyecto
  name String @db.VarChar(150)
  description String @db.Text
  objectives String? @db.Text
  status ProjectStatus
  visibility Visibility
   //timestamps
  startDate DateTime?
  endDate DateTime?
  publishedAt DateTime?
  createdAt DateTime @default(now())
  //Cada proyecto solo pertenece a un pillar
  pillar Pillar @relation(fields: [pillarId],references: [id])
  //Cada proyecto tiene un solo creador
  creator User @relation(fields: [createdBY],references: [id])
  //Relacion 1 to Many
  //Un projecto puede tener muchos eventos relacionados
  events Event[]
  //Relacion 1 to Many
  //Un proyecto puede tener muchas reseñas
  reviews ProjectReview []
  @@map("projects")
}

model Event{
  id Int @id @default(autoincrement())
  projectId Int
  createdBY Int // id del usuario que creo el evento
  visibility Visibility
  name String @db.VarChar(150)
  description String? @db.Text
  eventDate DateTime
  location String? @db.VarChar(150)
  volunteersNeeded Int @default(0)
  status EventStatus
  //timestamps
  startDate DateTime?
  endDate DateTime?
  publishedAt DateTime?
  createdAt DateTime @default(now())
  //Cada evento tiene un solo creador
  creator User @relation(fields: [createdBY],references: [id])
  //Un evento solo pertenece a un proyecto
  project Project @relation(fields: [projectId],references: [id])
  //Relacion 1 to Many
  //Un evento puede tener muchas tareas
  tasks Task[]
  //Relacion Many to Many
  //Un evento puede tener muchos asistentes
  volunteers EventVolunteer[]
  @@map("events")
}

model Task {
  id Int @id @default(autoincrement())
  eventId Int
  createdBY Int // id del usuario que creo la tarea
  title String @db.VarChar(150)
  description String? @db.Text
  priority TaskPrio
  taskStatus TaskStatus
  //timestamps
  startDate DateTime?
  dueDate DateTime?
  createdAt DateTime @default(now())
  //Cada evento tiene un solo creador
  creator User @relation(fields: [createdBY],references: [id])  
  //Una tarea pertenece solo a un evento
  event Event @relation(fields: [eventId],references: [id])
  //Relacion 1 to Many
  //Una tarea puede tener varios responsables
  assignedTo TaskVolunteer[]
  taskEvidences TaskEvidence[]
  @@map("tasks")
}

//ASK-->Una tarea puede estar asignada a muchos volutarios o solo a uno?
model TaskVolunteer{
  taskId Int 
  volunteerId Int 
  assignedAt DateTime @default(now())
  acceptedAt DateTime?
  startedAt DateTime?
  submittedAt DateTime?
  completedAt DateTime?
  status AssignmentStatus
  completionNote String? @db.Text
  task Task @relation(fields: [taskId],references: [id])
  volunteer Volunteer @relation(fields: [volunteerId],references: [id])

  //Llave compuesta para asegurar que una tarea pueda ser asignada una sola vez por voluntario
  @@id([taskId,volunteerId])
  @@map("tasks_volunteers")
}
//TODO--> Se debe validar que el usuario si tenga asignaciones a esta tarea
model TaskEvidence {
  id Int @id @default(autoincrement())
  taskId Int 
  volunteerId Int 
  reviewBy Int? //Persona que revisa la evidencia
  fileUrl String @db.Text
  fileType FileType
  description String? @db.Text
  uploadedAt DateTime @default(now())
  status ReviewStatus
  //Una evidencia pertenece a una tarea 
  task Task @relation(fields: [taskId],references: [id])
  //Una evidencia pertenece a un voluntario
  volunteer Volunteer @relation(fields: [volunteerId],references: [id])
  //Una evidencia solo puede ser revisada por una persona
  userReviewed User? @relation(fields: [reviewBy], references: [id])
  @@map("tasks_evidences")
}

