// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//Enums
enum Role {
  ADMIN
  COORDINATOR
  MODERATOR
  VOLUNTEER
  PYME_MANAGER
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EventStatus {
  PLANNED
  OPEN
  CLOSED
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
  CANCELLED
}

enum AssignmentStatus {
  PENDING_ACCEPTANCE
  ACCEPTED
  DECLINED
  IN_PROGRESS
  SUBMITTED
  UNDER_REVIEW
  REVISION_REQUESTED
  APPROVED
  REJECTED
  CANCELLED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ParticipationStatus {
  REGISTERED
  ATTENDED
  ABSENT
  CANCELLED
}

enum TaskPrio {
  LOW
  MEDIUM
  HIGH
}

enum Visibility {
  PUBLIC
  PRIVATE
}

enum FileType {
  IMAGE
  VIDEO
  DOCUMENT
  OTHER
}

enum NotificationType {
  TASK_ASSIGNMENT
  TASK_COMMENT
  TASK_EVIDENCE
  EVENT_UPDATE
  PROJECT_UPDATE
  REVIEW_REQUEST
  GENERAL
}

enum ActivityAction {
  CREATED
  UPDATED
  DELETED
  STATUS_CHANGED
  REGISTERED
  UNREGISTERED
  ASSIGNED
  ACCEPTED
  DECLINED
  SUBMITTED
  REVIEWED
  CANCELLED
}

enum ActorType {
  USER
  SYSTEM
}

//--------------------------------------------------
//Schema (Tablas de la bd)
model User {
  id               Int            @id @default(autoincrement())
  name             String         @db.VarChar(100)
  email            String         @unique @db.VarChar(150)
  password         String         @db.VarChar(255)
  imageUrl         String?        @db.VarChar(255)
  isActive         Boolean
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  userRoles        UserRole[]
  volunteers       Volunteer?
  pillar           Pillar?
  projects         Project[]
  events           Event[]
  tasks            Task[]
  evidenceReviewed TaskEvidence[]
  pyme             PymeManager?
  posts            BlogPost[]
  sessions         Session[]
  notifications    Notification[]
  activityLogs     ActivityLog[]  @relation("ActorLogs")
  taskComments     TaskComment[]

  @@map("users")
}

model UserRole {
  userId Int
  role   Role
  user   User @relation(fields: [userId], references: [id])

  @@id([userId, role])
  @@index([userId])
  @@map("user_roles")
}

model Session {
  id          Int      @id @default(autoincrement())
  userId      Int
  refreshHash String
  userAgent   String?
  ip          String?
  revoked     Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("sessions")
}

model Pillar {
  id            Int       @id @default(autoincrement())
  coordinatorId Int       @unique
  name          String    @db.VarChar(100)
  description   String    @db.Text
  iconUrl       String
  color         String    @db.VarChar(30)
  isActive      Boolean   @default(true)
  coordinator   User?     @relation(fields: [coordinatorId], references: [id])
  projects      Project[]
  news          News[]

  @@index([coordinatorId])
  @@map("pillars")
}

model Volunteer {
  id                    Int                     @id @default(autoincrement())
  userId                Int                     @unique
  phone                 String
  nationality           String
  profession            String
  emergencyContactName  String
  emergencyContactPhone String
  inmediateAvailability Boolean
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  user                  User                    @relation(fields: [userId], references: [id])
  skills                VolunteerSkill[]
  availability          VolunteerAvailability[]
  assignments           TaskAssignment[]
  taskEvidences         TaskEvidence[]
  participations        EventParticipation[]
  reviews               ProjectReview[]
  news                  News[]

  @@index([userId])
  @@map("volunteers")
}

model VolunteerAvailability {
  id          Int       @id @default(autoincrement())
  volunteerId Int
  startDate   DateTime
  endDate     DateTime
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id])

  @@index([volunteerId])
  @@map("volunteer_availabilities")
}

model VolunteerSkill {
  id          Int       @id @default(autoincrement())
  volunteerId Int
  name        String    @db.VarChar(100)
  description String    @db.Text
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id])

  @@index([volunteerId])
  @@map("volunteer_skills")
}

model Project {
  id          Int             @id @default(autoincrement())
  pillarId    Int
  createdBy   Int
  name        String          @db.VarChar(150)
  description String          @db.Text
  photoUrl    String?         @db.VarChar(255)
  objectives  String?         @db.Text
  status      ProjectStatus
  visibility  Visibility
  startDate   DateTime?
  endDate     DateTime?
  publishedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  pillar      Pillar          @relation(fields: [pillarId], references: [id])
  creator     User            @relation(fields: [createdBy], references: [id])
  events      Event[]
  reviews     ProjectReview[]
  news        News[]

  @@index([pillarId])
  @@index([createdBy])
  @@map("projects")
}

model Event {
  id               Int                  @id @default(autoincrement())
  projectId        Int
  createdBy        Int
  visibility       Visibility
  name             String               @db.VarChar(150)
  description      String?              @db.Text
  eventDate        DateTime
  location         String?              @db.VarChar(150)
  volunteersNeeded Int                  @default(0)
  status           EventStatus
  startDate        DateTime?
  endDate          DateTime?
  publishedAt      DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  creator          User                 @relation(fields: [createdBy], references: [id])
  project          Project              @relation(fields: [projectId], references: [id])
  tasks            Task[]
  participations   EventParticipation[]
  news             News[]

  @@index([projectId])
  @@index([createdBy])
  @@map("events")
}

model Task {
  id            Int              @id @default(autoincrement())
  eventId       Int
  createdBy     Int
  title         String           @db.VarChar(150)
  description   String?          @db.Text
  priority      TaskPrio
  taskStatus    TaskStatus
  startDate     DateTime?
  dueDate       DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  creator       User             @relation(fields: [createdBy], references: [id])
  event         Event            @relation(fields: [eventId], references: [id])
  assignments   TaskAssignment[]
  taskEvidences TaskEvidence[]
  comments      TaskComment[]

  @@index([eventId])
  @@index([createdBy])
  @@map("tasks")
}

model TaskAssignment {
  taskId         Int
  volunteerId    Int
  eventId        Int
  assignedBy     Int?
  assignedAt     DateTime         @default(now())
  acceptedAt     DateTime?
  declinedAt     DateTime?
  declineReason  String?          @db.Text
  startedAt      DateTime?
  submittedAt    DateTime?
  completedAt    DateTime?
  status         AssignmentStatus
  completionNote String?          @db.Text
  updatedAt      DateTime         @updatedAt

  task               Task               @relation(fields: [taskId], references: [id])
  volunteer          Volunteer          @relation(fields: [volunteerId], references: [id])
  eventParticipation EventParticipation @relation(fields: [eventId, volunteerId], references: [eventId, volunteerId])
  evidences          TaskEvidence[]

  @@id([taskId, volunteerId])
  @@index([eventId, volunteerId])
  @@index([volunteerId])
  @@map("task_assignments")
}

model TaskEvidence {
  id          Int          @id @default(autoincrement())
  taskId      Int
  volunteerId Int
  reviewBy    Int?
  fileUrl     String       @db.Text
  fileName    String       @db.VarChar(255)
  fileSize    Int          @default(0)
  fileType    FileType
  description String?      @db.Text
  reviewNote  String?      @db.Text
  uploadedAt  DateTime     @default(now())
  reviewedAt  DateTime?
  status      ReviewStatus
  updatedAt   DateTime     @updatedAt

  task         Task           @relation(fields: [taskId], references: [id])
  volunteer    Volunteer      @relation(fields: [volunteerId], references: [id])
  assignment   TaskAssignment @relation(fields: [taskId, volunteerId], references: [taskId, volunteerId])
  userReviewed User?          @relation(fields: [reviewBy], references: [id])

  @@index([taskId, volunteerId])
  @@index([volunteerId])
  @@index([reviewBy])
  @@map("tasks_evidences")
}

model TaskComment {
  id        Int      @id @default(autoincrement())
  taskId    Int
  authorId  Int
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id])
  author User @relation(fields: [authorId], references: [id])

  @@index([taskId])
  @@index([authorId])
  @@map("task_comments")
}

model EventParticipation {
  eventId      Int
  volunteerId  Int
  status       ParticipationStatus @default(REGISTERED)
  registeredAt DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  volunteer   Volunteer        @relation(fields: [volunteerId], references: [id])
  event       Event            @relation(fields: [eventId], references: [id])
  assignments TaskAssignment[]

  @@id([eventId, volunteerId])
  @@index([volunteerId])
  @@map("event_participations")
}

model ProjectReview {
  id          Int       @id @default(autoincrement())
  projectId   Int
  volunteerId Int
  rating      Int
  comment     String    @db.Text
  createdAt   DateTime  @default(now())
  project     Project   @relation(fields: [projectId], references: [id])
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id])

  @@index([projectId])
  @@index([volunteerId])
  @@map("projects_reviews")
}

model Pyme {
  id            Int          @id @default(autoincrement())
  name          String       @db.VarChar(150)
  description   String?
  category      String       @db.VarChar(100)
  phone         String       @db.VarChar(30)
  email         String?      @db.VarChar(150)
  logoUrl       String?      @db.Text
  coverImageUrl String?      @db.Text
  catalogSlug   String       @unique @db.VarChar(100)
  isActive      Boolean      @default(true)
  isFeatured    Boolean      @default(false)
  publishedAt   DateTime?
  createdAt     DateTime     @default(now())
  manager       PymeManager?
  products      Product[]

  @@map("pymes")
}

model PymeManager {
  id     Int     @id @default(autoincrement())
  pymeId Int     @unique
  userId Int     @unique
  name   String  @db.VarChar(150)
  phone  String  @db.VarChar(30)
  email  String? @db.VarChar(150)
  user   User    @relation(fields: [userId], references: [id])
  pyme   Pyme    @relation(fields: [pymeId], references: [id])

  @@map("pymes_managers")
}

model Product {
  id          Int       @id @default(autoincrement())
  pymeId      Int
  name        String    @db.VarChar(150)
  description String    @db.Text
  price       Decimal   @db.Decimal(12, 2)
  imageUrl    String    @db.Text
  isFeatured  Boolean   @default(false)
  isActive    Boolean   @default(true)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  pyme        Pyme      @relation(fields: [pymeId], references: [id])

  @@index([pymeId])
  @@map("products")
}

model News {
  id          Int        @id @default(autoincrement())
  pillarId    Int
  projectId   Int?
  eventId     Int?
  createdBy   Int
  title       String     @db.VarChar(180)
  summary     String?    @db.Text
  content     String     @db.Text
  imageUrl    String     @db.Text
  status      BlogStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())

  pillar  Pillar    @relation(fields: [pillarId], references: [id])
  project Project?  @relation(fields: [projectId], references: [id])
  event   Event?    @relation(fields: [eventId], references: [id])
  creator Volunteer @relation(fields: [createdBy], references: [id])

  @@index([pillarId])
  @@index([projectId])
  @@index([eventId])
  @@index([createdBy])
  @@map("news")
}

model BlogPost {
  id          Int        @id @default(autoincrement())
  authorId    Int
  title       String     @db.VarChar(180)
  summary     String?    @db.Text
  content     String     @db.Text
  imageUrl    String     @db.Text
  status      BlogStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  author      User       @relation(fields: [authorId], references: [id])

  @@index([authorId])
  @@map("blog_posts")
}

model Notification {
  id                Int              @id @default(autoincrement())
  userId            Int
  title             String           @db.VarChar(150)
  message           String           @db.Text
  type              NotificationType
  relatedEntityType String?          @db.VarChar(50)
  relatedEntityId   String?          @db.VarChar(50)
  actionUrl         String?          @db.VarChar(255)
  isRead            Boolean          @default(false)
  createdAt         DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model ActivityLog {
  id            Int            @id @default(autoincrement())
  actorId       Int
  actorType     ActorType
  action        ActivityAction
  entityType    String         @db.VarChar(50)
  entityId      Int
  eventId       Int?
  previousState Json?
  newState      Json?
  createdAt     DateTime       @default(now())

  actor User @relation("ActorLogs", fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([eventId, createdAt])
  @@index([actorId])
  @@map("activity_logs")
}
