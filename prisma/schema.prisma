//ASK--> las reviews son solo para proyectos o tambien para eventos?
model ProjectReview {
  id Int @id @default(autoincrement())
  projectId Int
  volunteerId Int
  rating Int
  comment String @db.Text
  createdAt DateTime @default(now())
  //Cada review pertenece a un proyecto
  project Project @relation(fields: [projectId],references: [id])
  //Una review es escrita por un unico voluntario
  volunteer Volunteer @relation(fields: [volunteerId],references: [id])
  @@map("projects_reviews")
}

model Pyme {
  id Int @id @default(autoincrement())
  name String @db.VarChar(150)
  description String?
  category String @db.VarChar(100)
  phone String @db.VarChar(30)
  email String? @db.VarChar(150)
  logoUrl String? @db.Text
  coverImageUrl String? @db.Text
  catalogSlug String @db.VarChar(100) @unique //URL personalizada para el catalogo de productos
  isActive Boolean @default(true)
  isFeatured Boolean @default(false)
  publishedAt DateTime? //Fecha en que se publicó o publicará el catalogo
  createdAt DateTime @default(now())
  //Relacion 1 to 1 
  //Una pyme solo puede tener un manager y un manager solo puede estar asociado a una pyme
  manager PymeManager?
   //Relacion 1 to many
  //Una pyme puede tener muchos productos
  products Product[]
  @@map("pymes")
}

model PymeManager {
  id Int @id @default(autoincrement())
  pymeId Int @unique
  userId Int @unique
  name String @db.VarChar(150)
  phone String @db.VarChar(30)
  email String? @db.VarChar(150)
  //Relacion 1 to 1
  //una pyme solo puede tener 1 manager 
  user User @relation(fields: [userId],references: [id])
  //Relacion 1 to 1 
  //Una pyme solo puede tener un manager y un manager solo puede estar asociado a una pyme
  pyme Pyme @relation(fields: [pymeId],references: [id])
 @@map("pymes_managers")
}

model Product{
  id Int @id @default(autoincrement())
  pymeId Int
  name String @db.VarChar(150)
  description String @db.Text
  price Decimal @db.Decimal(12,2)
  imagenUrl String  @db.Text
  isFeatured  Boolean @default(false)
  isActive Boolean @default(true)
  publishedAt DateTime?
  createdAt DateTime @default(now())
  //Relacion 1 to many
  //Un producto pertenece solo a una pyme
  pyme Pyme @relation(fields: [pymeId],references: [id])
  @@map("products")
}

model News {
  id Int @id @default(autoincrement())
  pillarId Int
  projectId Int? //No es obligatorio que una noticia esté  relacionada a un project
  eventId Int? //No es obligatorio que una noticia esté  relacionada a un event
  createdBy Int //Usuario que crea la noticia
  title String @db.VarChar(180)
  summary String? @db.Text
  content String @db.Text
  imagenUrl String  @db.Text
  status 
  

}



